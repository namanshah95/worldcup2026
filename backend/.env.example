# Backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SESSION_SECRET=generate-a-random-string
CORS_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
ADMIN_SECRET=your-admin-secret-for-match-updates
ATTENDANCE_BONUS_POINTS=4

# Live sports sync — TheStatsAPI (7-day trial: https://www.thestatsapi.com)
SPORTS_API_KEY=your-thestatsapi-bearer-token
SPORTS_API_PROVIDER=thestatsapi
THESTATSAPI_COMPETITION_ID=
THESTATSAPI_SEASON_ID=
SPORTS_SYNC_INTERVAL=30

# Alternative: Sportmonks (requires paid World Cup plan)
# SPORTS_API_PROVIDER=sportmonks
# SPORTMONKS_LEAGUE_ID=732
# SPORTMONKS_SEASON_ID=26618
