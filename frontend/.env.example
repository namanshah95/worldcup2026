# Option A (recommended on Railway): leave VITE_API_URL unset and proxy via nginx.
# Set this runtime variable on the frontend Railway service (no frontend rebuild needed):
#   BACKEND_URL=https://your-backend.up.railway.app
VITE_API_URL=

# Option B: call the backend directly (set at build time; also set CORS_ORIGINS on backend)
# VITE_API_URL=https://your-backend.up.railway.app

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
