# Option A (recommended on Railway): leave VITE_API_URL unset and proxy via nginx.
# Set BACKEND_URL as a runtime env var on the frontend service (no rebuild needed):
#   BACKEND_URL=https://your-backend.up.railway.app
VITE_API_URL=

# Option B: call the backend directly (requires CORS_ORIGINS on backend + rebuild on change)
# VITE_API_URL=https://your-backend.up.railway.app

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
